# --- Public deployment ---
DOMAIN=your-subdomain.duckdns.org
EMAIL=you@example.com
WEBAPP_URL=https://your-subdomain.duckdns.org

# --- Telegram bot ---
BOT_TOKEN=replace-with-your-telegram-bot-token
BOT_USERNAME=your_bot_username

# --- TON testnet ---
TON_NETWORK=testnet
CONTRACT_ADDRESS=replace-with-deployed-contract-address
TON_API_ENDPOINT=https://testnet.toncenter.com/api/v2
TON_API_KEY=
POLL_INTERVAL_SEC=12

# --- Backend ---
SQLITE_PATH=/data/indexer.db
BACKEND_PORT=8080

# --- Frontend (Vite build args) ---
VITE_API_BASE_URL=https://your-subdomain.duckdns.org/api
VITE_CONTRACT_ADDRESS=replace-with-deployed-contract-address
VITE_TON_NETWORK=testnet
VITE_TONCONNECT_MANIFEST_URL=https://your-subdomain.duckdns.org/tonconnect-manifest.json
